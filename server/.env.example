# Backend env vars (DO NOT COMMIT real secrets)

# Email (Gmail SMTP via Nodemailer)
EMAIL_USER=branditfirm080@gmail.com
# Create this in Google Account -> Security -> App passwords (requires 2-Step Verification)
EMAIL_APP_PASSWORD=PASTE_APP_PASSWORD_HERE

# Optional: who receives inbound requests (defaults to branditfirm080@gmail.com)
EMAIL_TO=branditfirm080@gmail.com
# Optional: From address (defaults to EMAIL_USER)
EMAIL_FROM=branditfirm080@gmail.com

# Paystack
PAYSTACK_SECRET_KEY=sk_live_or_sk_test_here

# Port for the API server
PORT=8787
